# Blake interview server (OpenAI-compatible custom LLM endpoint for ElevenAgents)
# Provider selection:
# - INTERVIEW_LLM_PROVIDER: openrouter | openai
# - INTERVIEW_EMBEDDING_PROVIDER: openrouter | openai | hash
INTERVIEW_LLM_PROVIDER=openrouter
INTERVIEW_LLM_API_KEY=
INTERVIEW_LLM_BASE_URL=
OPENROUTER_MODEL_INTERVIEW=openai/gpt-5-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_NAME="Blake AI Interview"

# Optional explicit embedding overrides
INTERVIEW_EMBEDDING_PROVIDER=openrouter
INTERVIEW_EMBEDDING_API_KEY=
INTERVIEW_EMBEDDING_BASE_URL=

# OpenAI fallback / compatibility vars
OPENAI_API_KEY=
OPENAI_MODEL_INTERVIEW=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://api.openai.com/v1

INTERVIEW_KNOWLEDGE_DIR=../blake/persona_interview/v1
INTERVIEW_CHARACTER_BIBLE_PATH=../blake/voice_builder/runs/blake_v1/07_character_bible.json
